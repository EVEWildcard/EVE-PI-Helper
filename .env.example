# ── EVE PI Planner (web) env vars ──
# Register your app at https://developers.eveonline.com/
#   • Connection type: Authentication & API Access (public/PKCE client, no secret)
#   • Callback URLs:
#       http://localhost:3000/api/auth/callback   (local `vercel dev`)
#       https://YOUR-DOMAIN.vercel.app/api/auth/callback   (production)
#   • Scopes: esi-planets.manage_planets.v1, esi-planets.read_customs_offices.v1,
#             esi-skills.read_skills.v1, esi-skills.read_skillqueue.v1
EVE_CLIENT_ID=your_client_id_here

# Secret used to encrypt the session cookie (32+ chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars
